# Bejundas Platform — Environment Variables Template
#
# Copy this file to `.env` and fill in real values.
# Never commit `.env` to git. This repository is public.
#
# Generate a SECRET_KEY:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
#
# Generate a GITHUB_WEBHOOK_SECRET:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"

# ----- Django -----
SECRET_KEY=replace-me-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# In production:
# DEBUG=False
# ALLOWED_HOSTS=bejundas.co.tz,www.bejundas.co.tz

# ----- Database (MySQL) -----
DB_NAME=bejundas_db
DB_USER=bejundas_dbuser
DB_PASS=replace-me
DB_HOST=localhost
DB_PORT=3306

# ----- Email -----
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=info@bejundas.co.tz
EMAIL_HOST_PASSWORD=replace-with-app-password
DEFAULT_FROM_EMAIL=Bejundas Group <info@bejundas.co.tz>

# Where contact-form messages from the hub go
CONTACT_EMAIL=info@bejundas.co.tz

# Where Coming Soon callback leads from /financial/, /construction/ etc. go
LEADS_EMAIL=info@bejundas.co.tz

# ----- Deploy webhook (production only) -----
# Generated independently from GitHub. Same value goes in GitHub repo Settings > Webhooks.
GITHUB_WEBHOOK_SECRET=replace-me-with-another-long-random-string

# ----- Static & media -----
STATIC_URL=/static/
MEDIA_URL=/media/
